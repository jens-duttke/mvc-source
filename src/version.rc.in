// Windows PE version resource template (the info Explorer's Properties > Details
// tab reads: FileVersion, ProductVersion, FileDescription, ...). Shared by both
// Windows DLLs; the Makefile fills in the @...@ placeholders with sed - the
// version numbers come from the single VERSION file at the repo root, and the
// per-DLL name/description are passed in by the caller. Generated files
// (*_version.rc) are not committed.
#include <winver.h>

VS_VERSION_INFO VERSIONINFO
FILEVERSION     @VER_MAJOR@,@VER_MINOR@,@VER_PATCH@,0
PRODUCTVERSION  @VER_MAJOR@,@VER_MINOR@,@VER_PATCH@,0
FILEFLAGSMASK   0x3fL
FILEFLAGS       0x0L
FILEOS          0x40004L  // VOS_NT_WINDOWS32
FILETYPE        0x2L      // VFT_DLL
FILESUBTYPE     0x0L
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "040904b0"  // US English, Unicode
        BEGIN
            VALUE "CompanyName", "Jens Duttke"
            VALUE "FileDescription", "@VER_DESCRIPTION@"
            VALUE "FileVersion", "@VER_STRING@"
            VALUE "InternalName", "@VER_FILENAME@"
            VALUE "LegalCopyright", "Copyright (c) 2026 Jens Duttke. BSD-3-Clause."
            VALUE "OriginalFilename", "@VER_FILENAME@"
            VALUE "ProductName", "mvc-source"
            VALUE "ProductVersion", "@VER_STRING@"
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x409, 1200
    END
END
